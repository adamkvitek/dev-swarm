# === Required API Keys ===

# Anthropic — Claude workers (CTO + developer agents)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — Codex reviewer agent
OPENAI_API_KEY=sk-...

# Discord — Bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# === Optional API Keys ===

# Perplexity — Research agent (looks up docs, APIs, best practices)
PERPLEXITY_API_KEY=pplx-...

# === Claude Adapter ===

# Path to the system prompt file (default: prompts/system.md)
# SYSTEM_PROMPT_PATH=prompts/system.md

# Ignore Discord messages older than this (default: 60000ms = 60s)
# Prevents processing old messages on startup/reconnect
# MAX_MESSAGE_AGE_MS=60000

# Claude CLI response timeout (default: 300000ms = 5 min)
# CLAUDE_RESPONSE_TIMEOUT_MS=300000

# Memory ceiling — refuse new work above this % (default: 80)
# MEMORY_CEILING_PCT=80

# === Pipeline Configuration ===

# Max review loop iterations (default: 3)
MAX_REVIEW_ITERATIONS=3

# Review quality threshold — APPROVE score needed to stop loop (default: 8)
REVIEW_QUALITY_THRESHOLD=8

# Max concurrent worker agents (default: 4, 50% of 8 cores)
MAX_CONCURRENT_WORKERS=4

# Working directory for code generation
WORKSPACE_DIR=~/dev/swarm-workspace

# === MCP Internal API ===

# Host/port for the internal HTTP API that bridges MCP server ↔ adapter
# Bound to localhost only — never exposed externally
# MCP_API_HOST=127.0.0.1
# MCP_API_PORT=9847
