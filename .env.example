# === Required API Keys ===

# Anthropic — Claude workers (CTO + developer agents)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — Codex reviewer agent
OPENAI_API_KEY=sk-...

# Discord — Bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# === Optional API Keys ===

# Perplexity — Research agent (looks up docs, APIs, best practices)
PERPLEXITY_API_KEY=pplx-...

# === Configuration ===

# Max review loop iterations (default: 10)
MAX_REVIEW_ITERATIONS=10

# Review quality threshold — APPROVE score needed to stop loop (default: 8)
REVIEW_QUALITY_THRESHOLD=8

# Working directory for code generation
WORKSPACE_DIR=~/dev/swarm-workspace
