# === Discord (only needed for Discord mode) ===

DISCORD_BOT_TOKEN=

# === CLI Paths (defaults work if tools are on PATH) ===

# CLAUDE_CLI=claude
# CODEX_CLI=codex
# GEMINI_CLI=gemini

# === Resource Limits (auto-detected from hardware if not set) ===

# Max concurrent worker agents (default: 75% of CPU cores, min 2)
# MAX_CONCURRENT_WORKERS=4

# Memory ceiling — pause worker spawning above this % (default: 92%)
# MEMORY_CEILING_PCT=92

# CPU ceiling — pause worker spawning above this % (default: 92%)
# CPU_CEILING_PCT=92

# === Review Configuration ===

# Max review loop iterations (default: 3)
# MAX_REVIEW_ITERATIONS=3

# Review quality threshold — average score needed to APPROVE (default: 8, range 1-10)
# REVIEW_QUALITY_THRESHOLD=8

# === Workspace ===

# Working directory for git worktrees (default: ~/dev/swarm-workspace)
# WORKSPACE_DIR=~/dev/swarm-workspace

# === Advanced ===

# System prompt path (default: prompts/system.md)
# SYSTEM_PROMPT_PATH=prompts/system.md

# Ignore Discord messages older than this (default: 60000ms = 60s)
# MAX_MESSAGE_AGE_MS=60000

# Claude CLI response timeout (default: 300000ms = 5 min)
# CLAUDE_RESPONSE_TIMEOUT_MS=300000

# Log level (default: info)
# LOG_LEVEL=info

# MCP internal API — localhost only, never exposed externally
# MCP_API_HOST=127.0.0.1
# MCP_API_PORT=9847

# === E2E Testing (Playwright — only needed for test:e2e) ===

# Full URL to a Discord channel where the bot is present.
# Replace SERVER_ID and CHANNEL_ID with your server and channel IDs.
# DISCORD_TEST_CHANNEL_URL=https://discord.com/channels/SERVER_ID/CHANNEL_ID

# Display name of your bot in Discord (as shown in the server member list).
# Replace YOUR_BOT_NAME with the name you gave your bot.
# DISCORD_BOT_NAME=YOUR_BOT_NAME
