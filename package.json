{
  "name": "dev-swarm",
  "version": "0.0.1",
  "description": "AI dev team orchestrator — Claude, Codex, and Gemini build software together with parallel workers, cross-model review, and isolated git worktrees",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/adamkvitek/dev-swarm.git"
  },
  "homepage": "https://github.com/adamkvitek/dev-swarm",
  "bugs": {
    "url": "https://github.com/adamkvitek/dev-swarm/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "claude",
    "codex",
    "gemini",
    "code-review",
    "mcp",
    "discord-bot",
    "orchestrator",
    "dev-tools"
  ],
  "author": "Adam Kvitek",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/dev-launcher.ts",
    "start": "node dist/index.js",
    "dev-swarm": "tsx src/dev-swarm.ts",
    "serve": "tsx src/serve.ts",
    "lint": "oxlint .",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:setup": "playwright test --project=setup --headed",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "discord.js": "^14.26.3",
    "dotenv": "^16.4.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.17",
    "oxlint": "^0.16.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "hono": "4.12.14",
    "path-to-regexp": "8.4.2"
  },
  "license": "MIT"
}
